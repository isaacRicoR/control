{
  "name": "controldev",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:control": "npm run dev --workspace=apps/control",
    "build:control": "npm run build --workspace=apps/control",
    "verify:structure": "node scripts/verify-structure.js && npm run lint",
    "scan:hardcodes": "node scripts/scan-hardcoded-colors.mjs",
    "scan:hardcodes:strict": "node scripts/scan-hardcoded-colors.mjs --strict",
    "check:ui-guards": "eslint packages/console/ui/patterns/form/FormActions.tsx packages/console/ui/containers/PanelCard packages/console/ui/atoms/Button --max-warnings 0 && node scripts/check-ui-guards.mjs"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  }
}
